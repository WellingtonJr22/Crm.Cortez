# ======= FRONT-END (expostas no navegador — apenas chaves públicas) =======
# URL do projeto Supabase (Dashboard > Settings > API)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Chave anônima (anon/public) do Supabase — pública por design
VITE_SUPABASE_ANON_KEY=coloque-a-anon-key-aqui

# ======= BACK-END (Netlify Functions — NUNCA expor no front) =======
SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Chave service_role do Supabase — SECRETA
SUPABASE_SERVICE_ROLE_KEY=coloque-a-service-role-key-aqui

# ======= WHATSAPP — API OFICIAL DA META (obrigatório para o chat funcionar) =======
# Token de acesso permanente do app na Meta Developers
META_ACCESS_TOKEN=
# Phone Number ID do número conectado à WhatsApp Business API
META_PHONE_NUMBER_ID=
# Token de verificação do webhook (você define esse valor e repete no painel da Meta)
META_VERIFY_TOKEN=defina-um-valor-secreto-aqui

# ======= IA (opcional — automações e sugestões de resposta) =======
# Chave da API da Anthropic (https://platform.claude.com)
ANTHROPIC_API_KEY=
